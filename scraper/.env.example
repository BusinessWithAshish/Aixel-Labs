# Server Configuration
HOST=0.0.0.0
PORT=8003
DEBUG=false

# Scraping Configuration
HEADLESS=true
MAX_RETRIES=3

# Optional: explicit HTTP proxy (used for Google search browser; overrides Evomi below)
# PROXY_URL=http://your_proxy:port

# Evomi residential (Google search when PROXY_URL unset; Instagram — same names as backend/.env)
# EVOMI_PROXY_USERNAME=
# EVOMI_PROXY_PASSWORD=
# EVOMI_PROXY_HOST=
# EVOMI_PROXY_PORT=

# Request timeout in seconds
REQUEST_TIMEOUT=30
