{
    "name": "aixellabs",
    "private": true,
    "packageManager": "pnpm@8.7.5",
    "scripts": {
        "installFE": "pnpm --filter frontend install",
        "installBE": "pnpm --filter backend install",
        "installBW": "pnpm --filter browser-worker install",
        "installAll": "pnpm installFE && pnpm installBE && pnpm installBW",
        "devAll": "pnpm devFE && pnpm devBE && pnpm devBW",
        "devFE": "pnpm --filter frontend dev",
        "devBE": "pnpm --filter backend run start",
        "devBW": "pnpm --filter browser-worker run dev",
        "prodBE": "pnpm --filter backend run start:prod",
        "prodBW": "pnpm --filter browser-worker run prod",
        "prodFE": "pnpm --filter frontend run prod"
    },
    "pnpm": {
        "patchedDependencies": {
            "node-tls-client@2.1.0": "patches/node-tls-client@2.1.0.patch"
        }
    }
}