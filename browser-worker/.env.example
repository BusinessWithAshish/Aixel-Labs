NODE_ENV=development
PORT=8080

# Evomi residential proxy credentials
EVOMI_PROXY_HOSTNAME=core-residential.evomi.com
EVOMI_PROXY_PORT=1000
EVOMI_PROXY_USERNAME=your_username
EVOMI_PROXY_PASSWORD=your_password

# Browser concurrency settings (optional — defaults shown)
MAX_BROWSER_SESSIONS=10
MAX_PAGES_PER_BROWSER=5
MAX_RETRIES=3
RETRY_DELAY=5000
RETRY_JITTER_MS=750
